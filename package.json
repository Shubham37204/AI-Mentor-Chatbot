{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently \"cd frontend && npm run dev\" \"cd backend && venv\\Scripts\\uvicorn app.main:app --reload\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && venv\\Scripts\\uvicorn app.main:app --reload",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && venv\\Scripts\\pip install -r requirements.txt"
  }
}
